# ============================================================================
# LexAI Perú - Backend Configuration Template
# Copia este archivo a .env y rellena los valores
# ============================================================================

# NODE
NODE_ENV=development
PORT=3000

# DATABASE - PostgreSQL
DATABASE_URL=postgresql://lexai:lexai_dev_password@localhost:5432/lexai_db
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000

# REDIS (Opcional para caché y rate limiting)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# JWT - DEBE SER SECRETO Y LARGO (>32 caracteres)
JWT_SECRET=your-super-secret-jwt-key-must-be-at-least-32-characters-long-change-me
JWT_REFRESH_SECRET=your-refresh-secret-also-must-be-at-least-32-characters-long-change-me

# API URLs
API_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# CORS
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# RATE LIMITING
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CLAUDE API (para procesamiento de consultas)
CLAUDE_API_KEY=sk-ant-xxxxx
CLAUDE_ENABLED=true

# MERCADO PAGO (para pagos)
MERCADO_PAGO_ACCESS_TOKEN=APP_USR_XXXXXXX
MERCADO_PAGO_ENABLED=false

# SENDGRID (para emails)
SENDGRID_API_KEY=SG.xxxxxxx
SENDGRID_FROM_EMAIL=noreply@lexai-peru.com
SENDGRID_ENABLED=false

# LOGGING
LOG_LEVEL=debug
LOG_FORMAT=combined

# BUSINESS RULES
CONSULTAS_GRATUITAS_MENSUALES=3
PRECIO_CONSULTA_SOLES=5
COMISION_LEXAI=70

# ============================================================================
# NOTAS DE CONFIGURACIÓN
# ============================================================================

# Production Checklist:
# - Cambiar NODE_ENV a "production"
# - Generar JWT_SECRET y JWT_REFRESH_SECRET verdaderamente aleatorios
# - Usar contraseña segura para PostgreSQL
# - Habilitar HTTPS en producción
# - Configurar CORS_ORIGINS con dominio real
# - Habilitar Redis para mejor performance
# - Configurar SendGrid para emails reales
# - Cambiar LOG_LEVEL a "info"
# - Usar variables de entorno seguras (AWS Secrets Manager, etc)
